<div style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:5% 1.25rem; background:#FDFBF7;">
  <div style="font-family:'PPEditorialNew',Georgia,serif; font-weight:800; font-size:2rem; letter-spacing:0.12em; margin-bottom:2rem;">AURA</div>
  <h1 class="text-h2" style="margin-bottom:1rem;">{{ shop.name }} is launching soon.</h1>
  <p style="font-size:0.95rem; color:rgba(26,26,26,0.55); max-width:36ch; line-height:1.7; margin-bottom:2.5rem;">{{ shop.password_message | default: 'We\'re putting the finishing touches on something exceptional.' }}</p>
  {% form 'storefront_password' %}
    {%- if form.errors -%}
      <p style="color:#c0392b; font-size:0.875rem; margin-bottom:1rem;">{{ form.errors.translated_fields['password'] | capitalize }} {{ form.errors.messages['password'] }}</p>
    {%- endif -%}
    <div style="display:flex; gap:0.75rem; align-items:center; justify-content:center; border-bottom:1px solid rgba(26,26,26,0.2); max-width:400px; margin:0 auto 1rem;">
      <input type="password" name="password" placeholder="Password" style="flex:1; border:none; background:none; outline:none; font-size:1rem; padding:0.75rem 0; font-family:system-ui; color:#1a1a1a;">
      <button type="submit" class="btn-secondary">Enter</button>
    </div>
  {% endform %}
</div>
{% schema %}
{ "name": "Password", "settings": [] }
{% endschema %}
