{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="pdp-wrap" data-section-id="{{ section.id }}" data-product-id="{{ product.id }}">

  <!-- ═══════════════════════════════════════════════════════════
       ABOVE THE FOLD: Gallery (58%) + Buy Box (42%)
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-top">

    <!-- ── DESKTOP GALLERY ────────────────────────────────────── -->
    <div class="pdp-gallery-col">
      <div class="pdp-main-image" id="pdp-main-image">
        {%- for image in product.images -%}
          <div class="pdp-slide{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}">
            {%- if forloop.first -%}
              {{ image | image_url: width: 1400 | image_tag: alt: image.alt, loading: 'eager', class: 'pdp-img' }}
            {%- else -%}
              {{ image | image_url: width: 1400 | image_tag: alt: image.alt, loading: 'lazy', class: 'pdp-img' }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <div class="pdp-thumbstrip" id="pdp-thumbstrip">
        {%- for image in product.images -%}
          <button
            class="pdp-thumb{% if forloop.first %} active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="View image {{ forloop.index }}"
          >
            {{ image | image_url: width: 120 | image_tag: loading: 'lazy', alt: image.alt }}
          </button>
        {%- endfor -%}
      </div>
    </div>

    <!-- ── MOBILE CAROUSEL ────────────────────────────────────── -->
    <div class="pdp-mobile-gallery">
      <div class="pdp-carousel-track" id="pdp-carousel-track">
        {%- for image in product.images -%}
          <div class="pdp-carousel-slide">
            {%- if forloop.first -%}
              {{ image | image_url: width: 900 | image_tag: alt: image.alt, loading: 'eager' }}
            {%- else -%}
              {{ image | image_url: width: 900 | image_tag: alt: image.alt, loading: 'lazy' }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <div class="pdp-carousel-dots" id="pdp-carousel-dots">
        {%- for image in product.images -%}
          <button class="pdp-dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    </div>

    <!-- ── BUY BOX ─────────────────────────────────────────────── -->
    <div class="pdp-info-col">

      <!-- Product name label -->
      <div class="pdp-eyebrow pdp-reveal" style="--delay:0s">{{ product.title }}</div>

      <!-- Marketing headline — the hook -->
      <h1 class="pdp-title pdp-reveal" style="--delay:0.07s">
        {{ section.settings.marketing_headline | default: 'The Last Training Short You&#39;ll Ever Buy.' }}
      </h1>

      <!-- Subheadline -->
      <p class="pdp-subhead pdp-reveal" style="--delay:0.13s">
        {{ section.settings.marketing_subhead | default: 'Engineered for athletes who refuse to compromise. 42km tested. Zero chafe. Dry in minutes. Designed in Athens for those who train like they mean it.' }}
      </p>

      <!-- Inline trust bar -->
      <div class="pdp-inline-trust pdp-reveal" style="--delay:0.18s">
        <span class="pdp-inline-trust-stars">★★★★★</span>
        <span class="pdp-inline-trust-score">{{ section.settings.review_score | default: '4.8' }} from {{ section.settings.review_count | default: '214' }} verified reviews</span>
        <span class="pdp-inline-trust-sep">|</span>
        <span>Free returns</span>
        <span class="pdp-inline-trust-sep">|</span>
        <span>Ships in 24h</span>
        <span class="pdp-inline-trust-sep">|</span>
        <span>2-year warranty</span>
      </div>

      <!-- Price row -->
      <div class="pdp-price-row pdp-reveal" style="--delay:0.22s">
        <div class="pdp-price" id="pdp-price">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="pdp-price-original">{{ current_variant.compare_at_price | money }}</span>
            <span class="pdp-price-sale">{{ current_variant.price | money }}</span>
          {%- else -%}
            <span>{{ current_variant.price | money }}</span>
          {%- endif -%}
        </div>
        <div class="pdp-rating-pill">
          <span class="pdp-stars">★★★★★</span>
          <span class="pdp-rating-num">{{ section.settings.review_score | default: '4.8' }}</span>
          <span class="pdp-rating-count">({{ section.settings.review_count | default: '214' }})</span>
        </div>
      </div>

      <!-- Urgency strip -->
      <div class="pdp-urgency pdp-reveal" style="--delay:0.27s">
        <div class="pdp-viewers">
          <span class="pdp-viewers-dot"></span>
          <span id="pdp-viewers-count">--</span>&nbsp;people viewing this right now
        </div>
        {%- if section.settings.show_stock_warning -%}
          <div class="pdp-stock-warn" id="pdp-stock-warn">
            <span class="pdp-stock-dot"></span>
            Only <strong id="pdp-stock-count">{{ section.settings.stock_count | default: '4' }}</strong> left in stock
          </div>
        {%- endif -%}
        {%- if section.settings.show_countdown -%}
          <div class="pdp-countdown">
            Order in <span id="pdp-countdown" class="pdp-countdown-timer">--:--:--</span> for same-day dispatch
          </div>
        {%- endif -%}
      </div>

      <!-- Product form -->
      {%- form 'product', product, id: 'pdp-form' -%}
        <input type="hidden" name="id" id="pdp-variant-id" value="{{ current_variant.id }}">

        <!-- Variant options -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="pdp-option-group pdp-reveal" style="--delay:{{ forloop.index | times: 0.06 | plus: 0.3 }}s">
              <div class="pdp-option-label">
                {{ option.name }}
                {%- if option.name == 'Size' -%}
                  <a href="/pages/size-guide" class="pdp-size-guide" target="_blank">Size guide</a>
                {%- endif -%}
              </div>
              <div class="pdp-variant-pills" data-option-index="{{ forloop.index0 }}">
                {%- for value in option.values -%}
                  {%- assign opt_idx = forloop.parentloop.index0 -%}
                  {%- assign is_available = false -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.available -%}
                      {%- assign opt_val = variant.options[opt_idx] -%}
                      {%- if opt_val == value -%}{%- assign is_available = true -%}{%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                  <button
                    type="button"
                    class="pdp-variant-pill{% unless is_available %} sold-out{% endunless %}{% if option.selected_value == value %} active{% endif %}"
                    data-option-index="{{ opt_idx }}"
                    data-option-value="{{ value | escape }}"
                    {% unless is_available %}aria-disabled="true"{% endunless %}
                  >{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- Qty + ATC -->
        <div class="pdp-buy-row pdp-reveal" style="--delay:0.44s">
          <div class="pdp-qty">
            <button type="button" class="pdp-qty-btn" id="pdp-qty-minus" aria-label="Decrease quantity">−</button>
            <input type="number" name="quantity" id="pdp-qty-input" value="1" min="1" max="99" class="pdp-qty-input" aria-label="Quantity">
            <button type="button" class="pdp-qty-btn" id="pdp-qty-plus" aria-label="Increase quantity">+</button>
          </div>
          <button
            type="submit"
            name="add"
            class="pdp-atc"
            id="pdp-atc-btn"
            {%- unless current_variant.available %} disabled aria-disabled="true"{%- endunless -%}
          >
            <span id="pdp-atc-label">
              {%- if current_variant.available -%}Get Yours{%- else -%}Sold Out{%- endif -%}
            </span>
            <span class="pdp-atc-arrow">→</span>
          </button>
        </div>

        <!-- ATC micro-copy -->
        <p class="pdp-atc-microcopy pdp-reveal" style="--delay:0.5s">Try it risk-free. 60-day returns, no questions.</p>

        <!-- Dynamic checkout -->
        {%- if section.settings.show_dynamic_checkout -%}
          <div class="pdp-dynamic-checkout">
            {{ form | payment_button }}
          </div>
        {%- endif -%}
      {%- endform -%}

      <!-- Trust strip -->
      <div class="pdp-trust pdp-reveal" style="--delay:0.54s">
        <div class="pdp-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Secure checkout</span>
        </div>
        <div class="pdp-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg>
          <span>Free returns</span>
        </div>
        <div class="pdp-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span>Ships in 24h</span>
        </div>
        <div class="pdp-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>2-year warranty</span>
        </div>
      </div>

    </div><!-- /pdp-info-col -->
  </div><!-- /pdp-top -->

  <!-- ═══════════════════════════════════════════════════════════
       LIFESTYLE BENTO GRID
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-bento">
    <div class="pdp-bento-hero">
      {%- if section.settings.bento_image_1 != blank -%}
        {{ section.settings.bento_image_1 | image_url: width: 1400 | image_tag: alt: section.settings.bento_image_1.alt, loading: 'lazy' }}
      {%- else -%}
        <img src="https://placehold.co/900x820/1a1a1a/fdfbf7?text=Lifestyle" alt="Lifestyle" loading="lazy">
      {%- endif -%}
      {%- if section.settings.bento_quote != blank -%}
        <div class="pdp-bento-quote">{{ section.settings.bento_quote }}</div>
      {%- endif -%}
    </div>
    <div class="pdp-bento-small">
      {%- if section.settings.bento_image_2 != blank -%}
        {{ section.settings.bento_image_2 | image_url: width: 800 | image_tag: alt: section.settings.bento_image_2.alt, loading: 'lazy' }}
      {%- else -%}
        <img src="https://placehold.co/600x560/2a2a26/fdfbf7?text=Detail" alt="Detail" loading="lazy">
      {%- endif -%}
    </div>
    <div class="pdp-bento-small">
      {%- if section.settings.bento_image_3 != blank -%}
        {{ section.settings.bento_image_3 | image_url: width: 800 | image_tag: alt: section.settings.bento_image_3.alt, loading: 'lazy' }}
      {%- else -%}
        <img src="https://placehold.co/600x260/d4cdc4/1a1a1a?text=Texture" alt="Texture" loading="lazy">
      {%- endif -%}
    </div>
    <div class="pdp-bento-banner"></div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       SECTION 1 — PAIN AMPLIFICATION
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-pain-section">
    <div class="pdp-pain-inner">
      <div class="pdp-section-label pdp-reveal">The problem</div>
      <h2 class="pdp-pain-headline pdp-reveal">You've Settled Long&nbsp;Enough.</h2>
      <div class="pdp-pain-body pdp-reveal">
        <p>You know the feeling. The shorts that ride up three kilometres into your run. The cheap mesh that chafes your thighs raw on leg day. The "performance fabric" that clings to your skin the second you start sweating — and smells like a gym bag by the end of the session.</p>
        <p>You've tried the big brands. The logo-covered gear that falls apart in two months. The "athletic fit" that's either too tight to move or too loose to look good. You keep buying replacements because nothing lasts.</p>
        <p>It's not your fault. Most training shorts are designed in boardrooms, not built for bodies that actually move under&nbsp;load.</p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       SECTION 2 — MECHANISM REVEAL
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-mechanism-section">
    <div class="pdp-mechanism-inner">
      <div class="pdp-section-label pdp-reveal">The solution</div>
      <h2 class="pdp-mechanism-headline pdp-reveal">Designed Where Athletes Actually&nbsp;Train.</h2>
      <div class="pdp-mechanism-body pdp-reveal">
        <p>Aura was born in Athens — where athletes train year-round in 35°C heat. Every stitch, every seam, every fibre was tested where comfort isn't optional. It's survival.</p>
        <p>The Aura Pro Training Short uses a proprietary cool-touch fabric that stays dry against your skin, doesn't cling when wet, and dries faster than anything you've worn. The tailored athletic cut moves with your body through squats, sprints, and marathons — without riding up, bunching, or restricting your range.</p>
        <p>This isn't another pair of shorts with a logo. This is precision athletic engineering for people who take training&nbsp;seriously.</p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       SECTION 3 — BENEFIT STACK
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-benefits-section">
    <div class="pdp-benefits-inner">
      <div class="pdp-section-label pdp-reveal">Why it works</div>
      <h2 class="pdp-benefits-headline pdp-reveal">Built Different. In Every Way That Matters.</h2>
      <div class="pdp-benefits-grid">

        <div class="pdp-benefit-card pdp-reveal" style="--delay:0.05s">
          <div class="pdp-benefit-num">01</div>
          <div class="pdp-benefit-body">
            <div class="pdp-benefit-feature">Cool-Touch Fabric Technology</div>
            <div class="pdp-benefit-desc">Proprietary moisture-wicking fabric stays dry against your skin even in extreme heat. No cling. No stick. No distraction.</div>
            <div class="pdp-benefit-feeling">You forget you're wearing them. All you feel is fast.</div>
          </div>
        </div>

        <div class="pdp-benefit-card pdp-reveal" style="--delay:0.1s">
          <div class="pdp-benefit-num">02</div>
          <div class="pdp-benefit-body">
            <div class="pdp-benefit-feature">Zero-Chafe Athletic Cut</div>
            <div class="pdp-benefit-desc">Tailored fit with flatlock seams and strategic panelling. Full range of motion for squats, sprints, lunges — no riding up, no bunching, no inner-thigh burn at kilometre 30.</div>
            <div class="pdp-benefit-feeling">The freedom to push harder without your gear fighting you.</div>
          </div>
        </div>

        <div class="pdp-benefit-card pdp-reveal" style="--delay:0.15s">
          <div class="pdp-benefit-num">03</div>
          <div class="pdp-benefit-body">
            <div class="pdp-benefit-feature">Rapid-Dry Construction</div>
            <div class="pdp-benefit-desc">Fabric dries in minutes, not hours. Whether it's sweat or rain, the shorts recover before you do. No heavy, waterlogged fabric dragging you down.</div>
            <div class="pdp-benefit-feeling">That light, second-skin sensation from start to finish.</div>
          </div>
        </div>

        <div class="pdp-benefit-card pdp-reveal" style="--delay:0.2s">
          <div class="pdp-benefit-num">04</div>
          <div class="pdp-benefit-body">
            <div class="pdp-benefit-feature">Built to Last — Guaranteed</div>
            <div class="pdp-benefit-desc">No pilling, no fading, no stretching — backed by a 2-year warranty. While other shorts fall apart in 8 weeks, these look and perform the same after 200 sessions.</div>
            <div class="pdp-benefit-feeling">The quiet confidence of owning gear that's as serious as you are.</div>
          </div>
        </div>

        <div class="pdp-benefit-card pdp-reveal" style="--delay:0.25s">
          <div class="pdp-benefit-num">05</div>
          <div class="pdp-benefit-body">
            <div class="pdp-benefit-feature">Functional Pockets That Actually Work</div>
            <div class="pdp-benefit-desc">Secure, bounce-free pockets sized for modern phones. Your phone stays locked in on 20km runs. No bouncing, no adjusting, no arm band needed.</div>
            <div class="pdp-benefit-feeling">One less thing to think about. Just run.</div>
          </div>
        </div>

        <div class="pdp-benefit-card pdp-reveal" style="--delay:0.3s">
          <div class="pdp-benefit-num">06</div>
          <div class="pdp-benefit-body">
            <div class="pdp-benefit-feature">Clean Design, No Logo Noise</div>
            <div class="pdp-benefit-desc">Minimalist design with no oversized branding. Looks as good at brunch as it does at the box. Wear it from the gym to the street without changing.</div>
            <div class="pdp-benefit-feeling">You look like someone who takes care of themselves — without trying.</div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       SECTION 4 — FEATURED SOCIAL PROOF
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-quotes-section">
    <div class="pdp-quotes-inner">
      <div class="pdp-section-label pdp-reveal">Real athletes. Real results.</div>
      <h2 class="pdp-quotes-headline pdp-reveal">Don't Take Our Word For It.</h2>
      <div class="pdp-quotes-score pdp-reveal">
        <span class="pdp-quotes-stars">★★★★★</span>
        <span class="pdp-quotes-rating">{{ section.settings.review_score | default: '4.8' }} from {{ section.settings.review_count | default: '214' }} verified reviews</span>
      </div>
      <div class="pdp-quotes-grid">

        <div class="pdp-quote-card pdp-reveal" style="--delay:0.05s">
          <div class="pdp-quote-stars">★★★★★</div>
          <p class="pdp-quote-text">"Best training shorts I've ever owned. I've tried everything from Nike to Lululemon. Nothing compares."</p>
          <div class="pdp-quote-author">
            <div class="pdp-quote-name">Marcus T.</div>
            <div class="pdp-quote-label">Verified Buyer</div>
          </div>
        </div>

        <div class="pdp-quote-card pdp-reveal" style="--delay:0.1s">
          <div class="pdp-quote-stars">★★★★★</div>
          <p class="pdp-quote-text">"Wore these at the Athens Classic Marathon. Comfortable from start to finish, zero chafe over 42km. That's the only endorsement you need."</p>
          <div class="pdp-quote-author">
            <div class="pdp-quote-name">Tom H.</div>
            <div class="pdp-quote-label">Marathon PB Holder</div>
          </div>
        </div>

        <div class="pdp-quote-card pdp-reveal" style="--delay:0.15s">
          <div class="pdp-quote-stars">★★★★★</div>
          <p class="pdp-quote-text">"I've recommended Aura to six people in my running club. All of them bought. All of them love it."</p>
          <div class="pdp-quote-author">
            <div class="pdp-quote-name">Maria V.</div>
            <div class="pdp-quote-label">Running Club Captain</div>
          </div>
        </div>

        <div class="pdp-quote-card pdp-reveal" style="--delay:0.2s">
          <div class="pdp-quote-stars">★★★★★</div>
          <p class="pdp-quote-text">"Three people asked where I got these at a race. Premium without the premium attitude."</p>
          <div class="pdp-quote-author">
            <div class="pdp-quote-name">Emma W.</div>
            <div class="pdp-quote-label">Triathlete</div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       PRODUCT DETAILS ACCORDION
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-details" id="pdp-details">

    <div class="pdp-accordion-item open">
      <button class="pdp-accordion-trigger" type="button" aria-expanded="true">
        <span>{{ section.settings.accordion_label_description | default: 'Description' }}</span>
        <svg class="pdp-accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="pdp-accordion-body">
        <div class="pdp-accordion-inner">{{ product.description }}</div>
      </div>
    </div>

    {%- if section.settings.accordion_body_sizing != blank -%}
      <div class="pdp-accordion-item">
        <button class="pdp-accordion-trigger" type="button" aria-expanded="false">
          <span>{{ section.settings.accordion_label_sizing | default: 'Sizing & Fit' }}</span>
          <svg class="pdp-accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="pdp-accordion-body">
          <div class="pdp-accordion-inner">{{ section.settings.accordion_body_sizing }}</div>
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.accordion_body_materials != blank -%}
      <div class="pdp-accordion-item">
        <button class="pdp-accordion-trigger" type="button" aria-expanded="false">
          <span>{{ section.settings.accordion_label_materials | default: 'Materials & Care' }}</span>
          <svg class="pdp-accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="pdp-accordion-body">
          <div class="pdp-accordion-inner">{{ section.settings.accordion_body_materials }}</div>
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.accordion_body_shipping != blank -%}
      <div class="pdp-accordion-item">
        <button class="pdp-accordion-trigger" type="button" aria-expanded="false">
          <span>{{ section.settings.accordion_label_shipping | default: 'Shipping & Returns' }}</span>
          <svg class="pdp-accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="pdp-accordion-body">
          <div class="pdp-accordion-inner">{{ section.settings.accordion_body_shipping }}</div>
        </div>
      </div>
    {%- endif -%}

  </div>

  <!-- ═══════════════════════════════════════════════════════════
       REVIEWS
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-reviews-section">
    {% render 'product-reviews' %}
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       SECTION 5 — GUARANTEE / RISK REVERSAL
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-guarantee-section">
    <div class="pdp-guarantee-inner">
      <div class="pdp-guarantee-badge pdp-reveal">60-Day Guarantee</div>
      <h2 class="pdp-guarantee-headline pdp-reveal">Try Them For 60 Days. If You're Not Obsessed, We'll Refund Every Penny.</h2>
      <p class="pdp-guarantee-body pdp-reveal">We're so confident these are the best training shorts you'll ever own that we'll take all the risk. Wear them. Train in them. Race in them. Put them through hell.</p>
      <p class="pdp-guarantee-body pdp-reveal">If they're not the most comfortable, best-performing shorts in your rotation after 60 days — send them back. Full refund. No questions. No forms. No hassle.</p>
      <p class="pdp-guarantee-emphasis pdp-reveal">You risk nothing. We risk everything. That's how confident we are.</p>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       SECTION 6 — FINAL CTA
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-finalcta-section">
    <div class="pdp-finalcta-inner">
      <h2 class="pdp-finalcta-headline pdp-reveal">Your Next Session Deserves Better Gear.</h2>
      <p class="pdp-finalcta-body pdp-reveal">You're one pair of shorts away from never thinking about what you're wearing mid-workout again. Zero chafe. Bone dry. Built to last years.</p>
      <div class="pdp-finalcta-btn-wrap pdp-reveal">
        <button class="pdp-atc pdp-finalcta-btn" id="pdp-finalcta-btn" type="button">
          <span>Get Yours</span>
          <span class="pdp-atc-arrow">→</span>
        </button>
        <p class="pdp-finalcta-microcopy">Free shipping &middot; 60-day risk-free guarantee &middot; 2-year warranty</p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       SECTION 7 — FAQ (OBJECTION KILLERS)
  ═══════════════════════════════════════════════════════════ -->
  <div class="pdp-faq-section">
    <div class="pdp-faq-inner">
      <div class="pdp-section-label pdp-reveal">Common questions</div>
      <h2 class="pdp-faq-headline pdp-reveal">Everything You Want to Know.</h2>

      <div class="pdp-faq-list" id="pdp-faq-list">

        <div class="pdp-accordion-item open">
          <button class="pdp-accordion-trigger" type="button" aria-expanded="true">
            <span>What makes these different from Nike / Lululemon / Under Armour?</span>
            <svg class="pdp-accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="pdp-accordion-body">
            <div class="pdp-accordion-inner">
              <p>Most big-brand shorts are designed for marketing, not movement. Aura Pro shorts are developed and tested by athletes training in extreme Mediterranean heat. The cool-touch fabric, tailored cut, and flatlock seams eliminate the three biggest complaints athletes have: chafing, cling, and poor durability. Our 214 five-star reviews from marathon runners, CrossFitters, and triathletes speak louder than any logo.</p>
            </div>
          </div>
        </div>

        <div class="pdp-accordion-item">
          <button class="pdp-accordion-trigger" type="button" aria-expanded="false">
            <span>Are they worth the price?</span>
            <svg class="pdp-accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="pdp-accordion-body">
            <div class="pdp-accordion-inner">
              <p>How much have you spent replacing cheap shorts that fall apart every few months? The Aura Pro is a one-time investment backed by a 2-year warranty. No pilling, no fading, no stretching. Customers report wearing the same pair for 200+ sessions. Do the math — this is the cheapest short you'll ever own per wear.</p>
            </div>
          </div>
        </div>

        <div class="pdp-accordion-item">
          <button class="pdp-accordion-trigger" type="button" aria-expanded="false">
            <span>How do they fit?</span>
            <svg class="pdp-accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="pdp-accordion-body">
            <div class="pdp-accordion-inner">
              <p>Athletic tailored fit — close to the body without being compression-tight. Designed to move with you through squats, sprints, and distance runs. If you're between sizes, we recommend sizing up for a more relaxed feel. Check our <a href="/pages/size-guide">sizing guide</a> for exact measurements.</p>
            </div>
          </div>
        </div>

        <div class="pdp-accordion-item">
          <button class="pdp-accordion-trigger" type="button" aria-expanded="false">
            <span>Can I wear these outside the gym?</span>
            <svg class="pdp-accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="pdp-accordion-body">
            <div class="pdp-accordion-inner">
              <p>Absolutely. The clean, logo-free design looks sharp from the gym to the coffee shop. Multiple customers mention wearing them casually without a second thought.</p>
            </div>
          </div>
        </div>

        <div class="pdp-accordion-item">
          <button class="pdp-accordion-trigger" type="button" aria-expanded="false">
            <span>What if they don't work for me?</span>
            <svg class="pdp-accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="pdp-accordion-body">
            <div class="pdp-accordion-inner">
              <p>Send them back within 60 days for a full refund. No questions. No hoops. We cover return shipping. The only risk is wondering why you didn't try them sooner.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       SUGGESTED PRODUCTS
  ═══════════════════════════════════════════════════════════ -->
  {%- if section.settings.suggested_collection != blank -%}
    {%- assign sugg_col = collections[section.settings.suggested_collection] -%}
    {%- if sugg_col != blank -%}
      <div class="pdp-suggested">
        <div class="pdp-suggested-header">
          <h2 class="pdp-suggested-title">{{ section.settings.suggested_title | default: 'You Might Also Like' }}</h2>
        </div>
        <div class="pdp-carousel-wrap">
          <div class="pdp-suggested-track" id="pdp-suggested-track">
            {%- for sugg in sugg_col.products limit: 8 -%}
              {%- unless sugg.id == product.id -%}
                <a href="{{ sugg.url }}" class="pdp-sugg-card">
                  <div class="pdp-sugg-img">
                    {{ sugg.featured_image | image_url: width: 600 | image_tag: alt: sugg.title, loading: 'lazy' }}
                  </div>
                  <div class="pdp-sugg-info">
                    <div class="pdp-sugg-name">{{ sugg.title }}</div>
                    <div class="pdp-sugg-price">{{ sugg.price | money }}</div>
                  </div>
                </a>
              {%- endunless -%}
            {%- endfor -%}
          </div>
          <button class="pdp-sugg-arrow pdp-sugg-prev" id="pdp-sugg-prev" aria-label="Previous">←</button>
          <button class="pdp-sugg-arrow pdp-sugg-next" id="pdp-sugg-next" aria-label="Next">→</button>
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}

</div><!-- /pdp-wrap -->

<!-- ── MOBILE STICKY ATC ─────────────────────────────────────── -->
<div class="pdp-sticky-atc" id="pdp-sticky-atc" aria-hidden="true">
  <div class="pdp-sticky-inner">
    <div class="pdp-sticky-info">
      <div class="pdp-sticky-title">{{ product.title }}</div>
      <div class="pdp-sticky-price" id="pdp-sticky-price">{{ current_variant.price | money }}</div>
    </div>
    <button class="pdp-atc pdp-sticky-btn" id="pdp-sticky-btn" type="button">
      <span>Get Yours</span>
      <span class="pdp-atc-arrow">→</span>
    </button>
  </div>
</div>

<!-- ── VARIANT DATA ──────────────────────────────────────────── -->
<script>
  window.__pdpData = {
    productId: {{ product.id }},
    variants: [
      {%- for variant in product.variants -%}
        {
          id: {{ variant.id }},
          title: {{ variant.title | json }},
          available: {{ variant.available }},
          price: {{ variant.price }},
          compareAtPrice: {{ variant.compare_at_price | default: 0 }},
          options: {{ variant.options | json }},
          featuredImageSrc: {% if variant.featured_image %}{{ variant.featured_image | image_url: width: 1400 | json }}{% else %}null{% endif %}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    optionNames: {{ product.options | json }},
    currentVariantId: {{ current_variant.id }}
  };
</script>
<script src="{{ 'product-urgency.js' | asset_url }}" defer></script>

